NODE_ENV=production
PORT=5001

# Provided automatically by Railway PostgreSQL addon — copy from Railway dashboard
DATABASE_URL=postgresql://user:password@host:5432/railway

# Generate strong random strings (min 32 chars)
JWT_SECRET=replace_with_strong_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_strong_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Set to your Railway app URL after first deploy
FRONTEND_URL=https://your-app.up.railway.app

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
BCRYPT_ROUNDS=12
LOG_LEVEL=info

# Razorpay — get from razorpay.com/dashboard
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# SMTP — Gmail app password / Brevo / SendGrid
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=EMR Platform
SMTP_FROM_EMAIL=no-reply@yourclinic.in
